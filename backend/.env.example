# Veritabanı
DB_HOST=localhost
DB_PORT=3306
# macOS Homebrew MySQL için socket bağlantısı (TCP yerine)
DB_SOCKET=/tmp/mysql.sock
DB_NAME=sporthink
DB_USER=root
DB_PASSWORD=rootroot
DB_CONNECTION_LIMIT=10

# Uygulama
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=change_this_secret_in_production_min_32_chars
JWT_EXPIRES_IN=7d
